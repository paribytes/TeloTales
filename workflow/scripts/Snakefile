configfile: "config.yaml"

import os

# =========================================================
# READ INPUT FILE LIST
# =========================================================
with open("files_list.txt") as f:
    FILES = [line.strip() for line in f if line.strip()]

BAM_FILES = [f for f in FILES if f.endswith(".bam")]
SAMPLES = sorted({os.path.basename(f).split(".")[0] for f in BAM_FILES})

OUTDIR = "results"
BAMDIR = "data/bam"

# =========================================================
# FINAL TARGET
# =========================================================
rule all:
    input:
        expand("data/bam/{bam}", bam=BAM_FILES),
        f"{OUTDIR}/ScaledGenomicOutput.txt",
        f"{OUTDIR}/stage2coverage.txt"

# =========================================================
# 1. DOWNLOAD BAM FILES
# =========================================================
rule download_bam:
    output:
        "data/bam/{bam}"
    params:
        base_url="https://ftp-trace.ncbi.nih.gov/1000genomes/ftp/phase3/data"
    shell:
        """
        mkdir -p data/bam
        wget -nc -P data/bam {params.base_url}/{wildcards.bam}
        """

# =========================================================
# 2. RUN QMOTIF
# =========================================================
rule run_qmotif:
    input:
        bam=f"{BAMDIR}/{{sample}}.bam"
    output:
        log="data/logs/{sample}_log.txt",
        txt="data/qmotif/{sample}_output.txt"
    shell:
        """
        mkdir -p data/logs data/qmotif

        qmotif -i qmotif.ini \
          --bam {input.bam} \
          --log {output.log} \
          -o {output.txt}
        """

# =========================================================
# 3. EXTRACT STAGE2 COVERAGE FROM LOGS
# =========================================================
rule extract_stage2_coverage:
    input:
        log="data/logs/{sample}_log.txt"
    output:
        "results/stage2/{sample}_stage2_coverage.txt"
    shell:
        """
        mkdir -p results/stage2

        grep 'GENOMIC' {input.log} | \
        awk '{{split($6, arr, ":"); print arr[1]"\\t"$18}}' | \
        sed 's/,/\\t/g' > {output}
        """

# =========================================================
# 4. AGGREGATE CHROMOSOME COVERAGE
# =========================================================
rule aggregate_chromosomes:
    input:
        files=expand("results/stage2/{sample}_stage2_coverage.txt", sample=SAMPLES),
        chrfile="workflow/scripts/chrnames.txt"

    output:
        "results/stage2coverage.txt"

    shell:
        """
        > {output}

        for file in {input.files}; do

            sed 's/^/chr/' "$file" > tmp && mv tmp "$file"

            while read chr; do
                x=$(grep "^$chr[[:space:]]" "$file" | awk '{{sum+=$2}} END {{print sum}}')
                echo "$file $chr $x" >> {output}
            done < {input.chrfile}

        done
        """

# =========================================================
# 5. EXTRACT SCALED GENOMIC READS
# =========================================================
rule extract_scaled_genomic:
    input:
        expand("data/qmotif/{sample}_output.txt", sample=SAMPLES)
    output:
        "results/ScaledGenomicOutput.txt"
    shell:
        """
        > {output}

        for file in {input}; do

            if [[ "$file" == *terminal* ]]; then
                continue
            fi

            filename=$(grep 'bam="' "$file" | sed 's|.*bam="[^/]\+/||;s|\\..*||')
            scaled=$(grep '<scaledGenomic' "$file" | sed 's|.*count="\\([0-9]\\+\\)".*|\\1|')

            echo "$filename $scaled" >> {output}
        done
        """
